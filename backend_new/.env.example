# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bggtdm_v2

# API keys
TANK01_API_KEY=your_rapidapi_key_here

# Admin key — required for all /admin/* endpoints
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=your_secret_admin_key_here

# ML model
MODEL_PATH=../ml/model/wr_te_model_v2.pkl
MODEL_VERSION=v2_xgb

# CORS — JSON array of allowed origins (pydantic-settings v2 requires JSON for list fields)
CORS_ORIGINS=["http://localhost:3000"]

# App
DEBUG=false
APP_NAME=BGGTDM API v2
