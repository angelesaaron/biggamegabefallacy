NEXT_PUBLIC_API_URL=http://localhost:8000

# DEV ONLY — fill these in .env.local ONLY. Never set in Vercel or any deployed env.
# NEXT_PUBLIC_* vars are compiled into the client JS bundle.
# Create the account: curl -X POST http://localhost:8000/api/auth/register \
#   -H "Content-Type: application/json" \
#   -d '{"email":"dev@local.test","password":"devpassword123"}'
# Then: UPDATE users SET tier='pro' WHERE email='dev@local.test';
NEXT_PUBLIC_DEV_USER_EMAIL=
NEXT_PUBLIC_DEV_USER_PASSWORD=
